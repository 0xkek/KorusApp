generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  walletAddress            String              @id @db.VarChar(44)
  tier                     String              @default("standard")
  walletSource             String              @default("app")
  genesisVerified          Boolean             @default(false)
  solBalance               Decimal             @default(0) @db.Decimal(18, 6)
  totalInteractionScore    Int                 @default(0)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  bio                      String?
  communityScore           Int                 @default(0)
  contentScore             Int                 @default(0)
  displayName              String?             @db.VarChar(50)
  engagementScore          Int                 @default(0)
  isSuspended              Boolean             @default(false)
  lastLoginDate            DateTime?
  lastRepUpdate            DateTime            @default(now())
  location                 String?             @db.VarChar(100)
  loginStreak              Int                 @default(0)
  loyaltyScore             Int                 @default(0)
  shoutoutScore            Int                 @default(0)
  nftAvatar                String?
  pushNotificationsEnabled Boolean             @default(true)
  pushToken                String?             @db.VarChar(255)
  reputationScore          Int                 @default(0)
  snsUsername              String?             @db.VarChar(100)
  username                 String?             @unique @db.VarChar(20)
  hasSetUsername           Boolean             @default(false)
  suspendedUntil           DateTime?
  suspensionReason         String?
  themeColor               String?             @db.VarChar(7)
  twitter                  String?             @db.VarChar(50)
  warningCount             Int                 @default(0)
  website                  String?             @db.VarChar(200)
  weekStartDate            DateTime?
  weeklyRepEarned          Int                 @default(0)
  // Subscription fields
  subscriptionType         String?             // "monthly" or "yearly" 
  subscriptionStatus       String?             @default("inactive") // "active", "inactive", "expired"
  subscriptionStartDate    DateTime?
  subscriptionEndDate      DateTime?           // When the current period ends
  subscriptionPrice        Decimal?            @db.Decimal(18, 6) // Price in SOL
  lastPaymentDate          DateTime?
  lastPaymentAmount        Decimal?            @db.Decimal(18, 6)
  lastPaymentTxSignature   String?             @db.VarChar(200)
  gamesAsPlayer1           Game[]              @relation("Player1Games")
  gamesAsPlayer2           Game[]              @relation("Player2Games")
  gamesWon                 Game[]              @relation("WonGames")
  interactions             Interaction[]
  moderatorActions         ModerationAction[]  @relation("Moderator")
  moderationActions        ModerationAction[]  @relation("ModeratedUser")
  sentNotifications        Notification[]      @relation("NotificationSender")
  notifications            Notification[]
  posts                    Post[]              @relation("AuthoredPosts")
  repEvents                RepEvent[]
  replies                  Reply[]
  reports                  Report[]
  tokenDistributions       TokenDistribution[]
  subscriptionPayments     SubscriptionPayment[]
  followers                Follow[]            @relation("Following") // users who follow this user
  following                Follow[]            @relation("Followers") // users this user follows
  followerCount            Int                 @default(0)
  followingCount           Int                 @default(0)

  @@index([tier, createdAt(sort: Desc)])
  @@index([totalInteractionScore(sort: Desc)])
  @@index([reputationScore(sort: Desc)])
  @@index([weeklyRepEarned(sort: Desc), weekStartDate])
  @@index([createdAt(sort: Desc)])
  @@index([isSuspended, suspendedUntil])
  @@index([username])
  @@index([snsUsername])
  @@map("users")
}

model Follow {
  id              String   @id @default(cuid())
  followerWallet  String   @db.VarChar(44)
  followingWallet String   @db.VarChar(44)
  createdAt       DateTime @default(now())

  follower        User     @relation("Followers", fields: [followerWallet], references: [walletAddress])
  following       User     @relation("Following", fields: [followingWallet], references: [walletAddress])

  @@unique([followerWallet, followingWallet])
  @@index([followerWallet])
  @@index([followingWallet])
  @@map("follows")
}

model Post {
  id               String         @id @default(cuid())
  authorWallet     String         @db.VarChar(44)
  content          String
  topic            String?        @db.VarChar(50)
  subtopic         String?        @db.VarChar(100)
  likeCount        Int            @default(0)
  replyCount       Int            @default(0)
  tipCount         Int            @default(0)
  tipAmount        Decimal        @default(0) @db.Decimal(18, 6) // Total SOL tipped
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  flaggedCount     Int            @default(0)
  imageUrl         String?
  isHidden         Boolean        @default(false)
  moderationReason String?
  videoUrl         String?
  isShoutout       Boolean        @default(false)
  shoutoutDuration Int?           // Duration in minutes
  shoutoutExpiresAt DateTime?     // When the shoutout expires
  shoutoutPrice    Decimal?       @db.Decimal(18, 6) // Price paid in SOL
  shoutoutTxSignature String?    @db.VarChar(128)   // On-chain payment tx signature
  isRepost         Boolean        @default(false)
  originalPostId   String?        // ID of the original post being reposted
  originalReplyId  String?        // ID of the original reply being reposted
  repostCount      Int            @default(0)
  repostComment    String?        // Optional comment on a repost (quote repost)
  game             Game?
  notifications    Notification[]
  author           User           @relation("AuthoredPosts", fields: [authorWallet], references: [walletAddress])
  originalPost     Post?          @relation("Reposts", fields: [originalPostId], references: [id])
  reposts          Post[]         @relation("Reposts")
  replies          Reply[]
  sponsoredPost    SponsoredPost?

  @@index([createdAt(sort: Desc)])
  @@index([authorWallet, createdAt(sort: Desc)])
  @@index([topic, createdAt(sort: Desc)])
  @@index([likeCount(sort: Desc)])
  @@index([content])
  @@index([isHidden, createdAt(sort: Desc)])
  @@index([flaggedCount(sort: Desc)])
  @@index([isShoutout, shoutoutExpiresAt(sort: Desc)])
  @@index([originalPostId])
  @@map("posts")
}

model Reply {
  id               String   @id @default(cuid())
  postId           String
  authorWallet     String   @db.VarChar(44)
  content          String
  parentReplyId    String?
  likeCount        Int      @default(0)
  tipCount         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  flaggedCount     Int      @default(0)
  isHidden         Boolean  @default(false)
  moderationReason String?
  imageUrl         String?  @db.VarChar(500)
  videoUrl         String?  @db.VarChar(500)
  author           User     @relation(fields: [authorWallet], references: [walletAddress])
  parentReply      Reply?   @relation("ReplyToReply", fields: [parentReplyId], references: [id])
  childReplies     Reply[]  @relation("ReplyToReply")
  post             Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([postId, isHidden, createdAt(sort: Desc)])
  @@index([authorWallet, createdAt(sort: Desc)])
  @@index([parentReplyId])
  @@index([isHidden, createdAt(sort: Desc)])
  @@index([flaggedCount(sort: Desc)])
  @@map("replies")
}

model Interaction {
  id              String   @id @default(cuid())
  userWallet      String   @db.VarChar(44)
  targetType      String   @db.VarChar(10)
  targetId        String
  interactionType String   @db.VarChar(10)
  amount          Decimal? @db.Decimal(18, 6)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userWallet], references: [walletAddress])

  @@unique([userWallet, targetId, interactionType])
  @@index([targetId, interactionType])
  @@index([userWallet, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("interactions")
}

model Game {
  id          String   @id @default(cuid())
  postId      String   @unique
  gameType    String   @db.VarChar(20)
  player1     String   @db.VarChar(44)
  player2     String?  @db.VarChar(44)
  currentTurn String?  @db.VarChar(44)
  gameState   Json
  wager       Decimal  @db.Decimal(18, 6)
  winner      String?  @db.VarChar(44)
  status      String   @db.VarChar(20)
  onChainGameId BigInt? // Blockchain game ID (u64)
  expiresAt   DateTime? // When the waiting game expires (2 hours)
  lastMoveAt  DateTime? // Last move timestamp (for 10-min move timeout)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  player1User User     @relation("Player1Games", fields: [player1], references: [walletAddress])
  player2User User?      @relation("Player2Games", fields: [player2], references: [walletAddress])
  post        Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  winnerUser  User?      @relation("WonGames", fields: [winner], references: [walletAddress])
  escrow      GameEscrow?

  @@index([status, createdAt(sort: Desc)])
  @@index([player1, status])
  @@index([player2, status])
  @@index([gameType, status])
  @@index([status, expiresAt])
  @@index([status, lastMoveAt])
  @@map("games")
}

model Report {
  id             String    @id @default(cuid())
  reporterWallet String    @db.VarChar(44)
  targetType     String    @db.VarChar(10)
  targetId       String
  reason         String    @db.VarChar(50)
  description    String?
  status         String    @default("pending") @db.VarChar(20)
  moderatorNotes String?
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  reporter       User      @relation(fields: [reporterWallet], references: [walletAddress])

  @@unique([reporterWallet, targetId])
  @@index([status, createdAt(sort: Desc)])
  @@index([targetId, targetType])
  @@index([reporterWallet, createdAt(sort: Desc)])
  @@index([reason, status])
  @@map("reports")
}

model ModerationAction {
  id              String   @id @default(cuid())
  moderatorWallet String   @db.VarChar(44)
  targetType      String   @db.VarChar(10)
  targetId        String
  actionType      String   @db.VarChar(20)
  reason          String
  duration        Int?
  reportId        String?
  createdAt       DateTime @default(now())
  moderator       User     @relation("Moderator", fields: [moderatorWallet], references: [walletAddress])
  targetUser      User     @relation("ModeratedUser", fields: [targetId], references: [walletAddress])

  @@index([targetType, targetId])
  @@index([moderatorWallet, createdAt(sort: Desc)])
  @@index([actionType, createdAt(sort: Desc)])
  @@index([reportId])
  @@map("moderation_actions")
}

model RepEvent {
  id          String   @id @default(cuid())
  userWallet  String   @db.VarChar(44)
  eventType   String   @db.VarChar(50)
  category    String   @db.VarChar(20)
  points      Int
  multiplier  Decimal  @default(1.0) @db.Decimal(3, 2)
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userWallet], references: [walletAddress], onDelete: Cascade)

  @@index([userWallet, createdAt(sort: Desc)])
  @@index([eventType])
  @@index([createdAt])
  @@map("rep_events")
}

model WeeklyRepPool {
  id                   String    @id @default(cuid())
  weekStartDate        DateTime  @unique @db.Date
  weekEndDate          DateTime  @db.Date
  distributionDate     DateTime  @db.Date
  sponsoredPostRevenue Decimal   @default(0) @db.Decimal(18, 6)
  gameFeesCollected    Decimal   @default(0) @db.Decimal(18, 6)
  eventFeesCollected   Decimal   @default(0) @db.Decimal(18, 6)
  platformFeePercent   Int       @default(50)
  totalPoolSize        Decimal   @default(0) @db.Decimal(18, 6)
  totalRepGenerated    Int       @default(0)
  participantCount     Int       @default(0)
  distributed          Boolean   @default(false)
  distributedAt        DateTime?
  createdAt            DateTime  @default(now())

  @@map("weekly_rep_pools")
}

model SponsoredPost {
  id            String   @id @default(cuid())
  postId        String   @unique
  sponsorWallet String   @db.VarChar(44)
  campaignName  String   @db.VarChar(100)
  pricePaid     Decimal  @db.Decimal(18, 6)
  startDate     DateTime
  endDate       DateTime
  targetViews   Int      @default(0)
  actualViews   Int      @default(0)
  clickCount    Int      @default(0)
  weekNumber    Int
  yearNumber    Int
  revenueShared Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([weekNumber, yearNumber, revenueShared])
  @@index([startDate, endDate])
  @@map("sponsored_posts")
}

model TokenDistribution {
  id                String    @id @default(cuid())
  userWallet        String    @db.VarChar(44)
  weekStartDate     DateTime  @db.Date
  weekEndDate       DateTime  @db.Date
  distributionDate  DateTime  @db.Date
  repEarned         Int
  sharePercentage   Decimal   @db.Decimal(6, 4)
  tokensEarned      Decimal   @db.Decimal(18, 6)
  weeklyPoolSize    Decimal   @db.Decimal(18, 6)
  totalParticipants Int
  claimed           Boolean   @default(false)
  claimedAt         DateTime?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userWallet], references: [walletAddress], onDelete: Cascade)

  @@unique([userWallet, weekStartDate])
  @@index([userWallet, distributionDate(sort: Desc)])
  @@index([claimed, userWallet])
  @@index([weekStartDate, weekEndDate])
  @@map("token_distributions")
}

model Notification {
  id         String   @id @default(cuid())
  userId     String   @db.VarChar(44)
  type       String   @db.VarChar(20)
  title      String
  message    String
  read       Boolean  @default(false)
  fromUserId String?  @db.VarChar(44)
  postId     String?
  amount     Decimal? @db.Decimal(18, 6)
  createdAt  DateTime @default(now())
  fromUser   User?    @relation("NotificationSender", fields: [fromUserId], references: [walletAddress])
  post       Post?    @relation(fields: [postId], references: [id])
  user       User     @relation(fields: [userId], references: [walletAddress])

  @@index([userId, read, createdAt(sort: Desc)])
  @@map("notifications")
}

model SubscriptionPayment {
  id                String   @id @default(cuid())
  walletAddress     String   @db.VarChar(44)
  subscriptionType  String   // "monthly" or "yearly"
  amount            Decimal  @db.Decimal(18, 6) // Amount in SOL
  txSignature       String   @unique @db.VarChar(200) // Solana transaction signature
  periodStart       DateTime
  periodEnd         DateTime
  createdAt         DateTime @default(now())
  
  user              User     @relation(fields: [walletAddress], references: [walletAddress])
  
  @@index([walletAddress, createdAt(sort: Desc)])
  @@map("subscription_payments")
}

model GameEscrow {
  id              String   @id @default(cuid())
  gameId          String   @unique
  player1Wallet   String   @db.VarChar(44)
  player2Wallet   String?  @db.VarChar(44)
  player1Amount   Decimal  @db.Decimal(18, 6) // Amount in SOL
  player2Amount   Decimal? @db.Decimal(18, 6) // Amount in SOL
  player1TxSig    String?  @unique @db.VarChar(200) // Transaction signature
  player2TxSig    String?  @unique @db.VarChar(200) // Transaction signature
  totalPot        Decimal  @db.Decimal(18, 6) // Total pot
  platformFee     Decimal  @db.Decimal(18, 6) // 2% fee
  winnerPayout    Decimal  @db.Decimal(18, 6) // 98% to winner
  status          String   @db.VarChar(20) // "pending", "locked", "paid", "refunded"
  payoutTxSig     String?  @unique @db.VarChar(200) // Payout transaction
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  game            Game     @relation(fields: [gameId], references: [id])

  @@index([status])
  @@map("game_escrows")
}

model Event {
  id                String                  @id @default(cuid())
  type              String                  @db.VarChar(20) // "whitelist", "airdrop", "mint", "beta"
  projectName       String                  @db.VarChar(100)
  title             String                  @db.VarChar(200)
  description       String                  @db.Text
  imageUrl          String?                 @db.VarChar(500)
  externalLink      String?                 @db.VarChar(500) // Project website/Discord (optional)

  // Whitelist Configuration
  maxSpots          Int?                    // null = unlimited
  startDate         DateTime
  endDate           DateTime
  selectionMethod   String                  @db.VarChar(20) // "fcfs", "lottery", "weighted_lottery"

  // Requirements (stored as JSON array)
  requirements      Json?                   // ["Hold 1+ SOL", "Active Korus user"]
  minReputation     Int?
  minAccountAge     Int?                    // days

  // Creator Info
  creatorWallet     String                  @db.VarChar(44)
  verified          Boolean                 @default(false) // Verified by Korus team
  featured          Boolean                 @default(false) // Paid promotion

  // Stats
  registrationCount Int                     @default(0)
  viewCount         Int                     @default(0)

  // Status
  status            String                  @default("active") @db.VarChar(20) // "active", "closed", "cancelled"

  // Timestamps
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  // Relations
  registrations     WhitelistRegistration[]

  @@index([type, status, startDate])
  @@index([creatorWallet, createdAt(sort: Desc)])
  @@index([status, endDate])
  @@index([featured, status, startDate])
  @@map("events")
}

model WhitelistRegistration {
  id                String   @id @default(cuid())
  eventId           String
  walletAddress     String   @db.VarChar(44)

  // Proof of ownership
  signature         String   @unique @db.Text // Wallet signature
  signedMessage     String   @db.Text // Message that was signed

  // User info at time of registration
  reputationScore   Int
  accountAge        Int      // days

  // Status
  status            String   @default("registered") @db.VarChar(20) // "registered", "waitlist", "selected", "rejected"
  position          Int?     // Queue position (for FCFS)
  selectedAt        DateTime? // If selected via lottery

  // Optional metadata (stored as JSON)
  metadata          Json?    // { twitter, discord, email }

  // Timestamps
  registeredAt      DateTime @default(now())

  // Relations
  event             Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, walletAddress])
  @@index([eventId, status, registeredAt])
  @@index([walletAddress, registeredAt(sort: Desc)])
  @@index([eventId, position])
  @@map("whitelist_registrations")
}

model PlatformConfig {
  key       String   @id @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("platform_config")
}
