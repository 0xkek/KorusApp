# Database (Railway/Render will provide this)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:PORT/railway

# Authentication
JWT_SECRET=generate-a-secure-random-string-here-at-least-32-chars

# Server
PORT=3000
NODE_ENV=production

# Solana - MAINNET
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_CLUSTER=mainnet-beta
HELIUS_API_KEY=your_helius_api_key_here

# Game Escrow Contract
GAME_ESCROW_PROGRAM_ID=4iUdAkPRmZLzUFXTLpt5QPGmUUtP6yfgpPpF3sLD9xtd
GAME_AUTHORITY_PUBKEY=your_game_authority_public_key

# Frontend URL
FRONTEND_URL=https://korus.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Mock Mode (MUST be false for production)
MOCK_MODE=false